@charset "utf-8";

pre code.hljs { padding: 1em; display: block; overflow-x: auto; }

code.hljs { padding: 3px 5px; }

.hljs { color: rgb(84, 84, 84); background: rgb(254, 254, 254); }

.hljs-comment, .hljs-quote { color: rgb(105, 105, 105); }

.hljs-variable, .hljs-template-variable, .hljs-tag, .hljs-name, .hljs-selec=
tor-id, .hljs-selector-class, .hljs-regexp, .hljs-deletion { color: rgb(217=
, 30, 24); }

.hljs-number, .hljs-built_in, .hljs-literal, .hljs-type, .hljs-params, .hlj=
s-meta, .hljs-link, .hljs-attribute { color: rgb(170, 93, 0); }

.hljs-string, .hljs-symbol, .hljs-bullet, .hljs-addition { color: green; }

.hljs-title, .hljs-section { color: rgb(0, 127, 170); }

.hljs-keyword, .hljs-selector-tag { color: rgb(121, 40, 161); }

.hljs-emphasis { font-style: italic; }

.hljs-strong { font-weight: 700; }

@media screen and (-ms-high-contrast:active) {
  .hljs-addition, .hljs-attribute, .hljs-built_in, .hljs-bullet, .hljs-comm=
ent, .hljs-link, .hljs-literal, .hljs-meta, .hljs-number, .hljs-params, .hl=
js-string, .hljs-symbol, .hljs-type, .hljs-quote { color: highlight; }
  .hljs-keyword, .hljs-selector-tag { font-weight: 700; }
}
